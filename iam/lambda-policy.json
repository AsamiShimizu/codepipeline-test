{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CodeDeployLifecycleHook",
      "Effect": "Allow",
      "Action": [
        "codedeploy:PutLifecycleEventHookExecutionStatus",
        "codedeploy:GetDeployment"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:ap-northeast-3:533876055951:log-group:/aws/lambda/*"
    }
  ]
}
